# AI Asset Generation — API keys and local server config
# Copy this file to .env and fill in your keys.
# .env is gitignored and must never be committed.

# --- Cloud API keys ---
OPENAI_API_KEY=
HUGGING_FACE=
ELEVENLABS_API_KEY=
REPLICATE_API_TOKEN=

# --- Local server auto-start commands ---
# These are used automatically when cloud generation fails.
# Servers live in the game-dev-tools submodule. Run first:
#   git submodule update --init vendor/game-dev-tools
# The servers install their own dependencies (torch, diffusers, audiocraft)
# on first run and download models from HuggingFace on first request.
# WARNING: CPU-only — sprite generation takes 5-20 min, audio 2-5 min.
LOCAL_SPRITE_START_CMD=python3 vendor/game-dev-tools/src/servers/local_sprite_server.py
LOCAL_SFX_START_CMD=python3 vendor/game-dev-tools/src/servers/local_audio_server.py
LOCAL_MUSIC_START_CMD=python3 vendor/game-dev-tools/src/servers/local_audio_server.py

# --- Local server URL overrides (optional) ---
# Uncomment to override the default localhost endpoints.
# LOCAL_SPRITE_URL=http://localhost:7860/sdapi/v1/txt2img
# LOCAL_SFX_URL=http://localhost:8080/generate/sfx
# LOCAL_MUSIC_URL=http://localhost:8080/generate/music

# --- Force local (skip cloud) ---
# FORCE_LOCAL_AI=1
