; Engine configuration file.
; It's best edited using the Godot editor (Tools > Project Settings...).
; Manual editing is also possible but the file should be verified in the editor.

config_version=5

[application]

config/name="Dudes in Alaska"
config/description="A 2D survival simulation game set in the Alaskan wilderness."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[autoload]

EventBus="*res://scripts/autoloads/event_bus.gd"
GameManager="*res://scripts/autoloads/game_manager.gd"
SceneManager="*res://scripts/autoloads/scene_manager.gd"
TimeManager="*res://scripts/autoloads/time_manager.gd"
WeatherManager="*res://scripts/autoloads/weather_manager.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
SaveManager="*res://scripts/autoloads/save_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

